{
  "name": "wespy",
  "version": "0.2.0",
  "description": "WeSpy - 文章抓取与 Markdown 转换工具 (TypeScript 版)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wespy": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "wechat",
    "article",
    "scraper",
    "markdown",
    "juejin"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.0.0",
    "turndown": "^7.1.0",
    "undici": "^6.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.1",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
