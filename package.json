{
    "name": "wespy-ts",
    "version": "1.1.0",
    "description": "WeSpy - 文章抓取与 Markdown 转换工具 (TypeScript 版)",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "bin": {
        "wespy": "dist/cli/main.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "tsc --noEmit",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "wechat",
        "article",
        "scraper",
        "markdown",
        "juejin",
        "fetch",
        "crawl"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Cuimc/WeSpy-TS.git"
    },
    "bugs": {
        "url": "https://github.com/Cuimc/WeSpy-TS/issues"
    },
    "homepage": "https://github.com/Cuimc/WeSpy-TS#readme",
    "sideEffects": false,
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "cheerio": "^1.0.0",
        "commander": "^12.0.0",
        "turndown": "^7.1.0",
        "undici": "^6.0.0",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/turndown": "^5.0.1",
        "typescript": "^5.4.0",
        "vitest": "^1.0.0"
    }
}